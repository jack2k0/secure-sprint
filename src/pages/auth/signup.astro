---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Demo accounts only">
  <main class="flex min-h-screen items-center justify-center bg-slate-100 p-4">
    <div class="max-w-md rounded-2xl bg-white p-8 text-center shadow-sm">
      <h1 class="text-xl font-bold text-slate-900">Demo accounts only</h1>
      <p class="mt-3 text-slate-600">Ask the workspace owner for your SecureSprint demo-account credentials.</p>
      <a
        href="/auth/signin"
        class="mt-5 inline-block rounded-lg bg-cyan-700 px-4 py-2 font-semibold text-white hover:bg-cyan-800"
      >
        Go to sign in
      </a>
    </div>
  </main>
</Layout>
